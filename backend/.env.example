# ===== NVIDIA / LLM =====
NVIDIA_API_KEY=nvapi-PLACEHOLDER
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
OPENROUTER_API_KEY=sk-or-v1-PLACEHOLDER
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ===== Model IDs (pinned per hackathon brief tip) =====
NEMOTRON_REASONER=nvidia/llama-3.3-nemotron-super-49b-v1
NEMOTRON_FAST=nvidia/nemotron-nano-9b-v2
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# ===== External APIs =====
TAVILY_API_KEY=tvly-PLACEHOLDER
OPENWEATHER_API_KEY=PLACEHOLDER
USDA_API_KEY=PLACEHOLDER

# ===== Paths (relative to backend/) =====
CHROMA_DIR=./data/chroma
SQLITE_PATH=./data/tulparai.db

# ===== Pipeline Tuning =====
CONFIDENCE_THRESHOLD=0.35
TOP_K_RETRIEVAL=15
TOP_K_RERANK=5
CHUNK_SIZE=600
CHUNK_OVERLAP=120

# ===== Server =====
PORT=8000
CORS_ORIGINS=http://localhost:3000,https://tulparai.vercel.app
